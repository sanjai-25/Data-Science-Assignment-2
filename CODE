import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from google.colab import files
uploaded = files.upload()
df = pd.read_csv('demand_forecasting_data.csv')
print(df.head())
print(df.info())
df = df.dropna()
df = df.drop_duplicates()
print("\nStatistical Summary:")
print(df.describe())
print("\nCorrelation between Price and Demand:")
print(df[['Price', 'Demand']].corr())
plt.figure()
plt.scatter(df['Price'], df['Demand'])
plt.xlabel('Price')
plt.ylabel('Demand')
plt.title('Price vs Demand Analysis')
plt.show()
plt.figure()
sns.scatterplot(x='Price', y='Demand', data=df)
plt.title('Price vs Demand (Seaborn)')
plt.show()
